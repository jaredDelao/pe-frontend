# Ruta base de la API. En desarrollo se usa /api, que Vite reenvía al mock
# (ver server.proxy en vite.config.ts) para evitar problemas de CORS.
VITE_API_URL=/api

# Destino del proxy de Vite hacia Mockoon. Cámbialo si tu mock corre en otro puerto.
VITE_MOCK_URL=http://localhost:3001

# Llave e IV para el cifrado AES de la venta (CBC).
# La llave debe ser de 16, 24 o 32 caracteres; el IV de 16.
VITE_AES_KEY=1234567890abcdef
VITE_AES_IV=abcdef1234567890
